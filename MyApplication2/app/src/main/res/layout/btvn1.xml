<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/iv1"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/img"
        android:layout_marginTop="60dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <TextView
        android:id="@+id/tx1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price : 3000$"
        android:textSize="30dp"
        app:layout_constraintLeft_toRightOf="@id/iv1"
        app:layout_constraintTop_toTopOf="@id/iv1"
        />
    <TextView
        android:id="@+id/tx2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="5"
        android:text="iPhone 17 sử dụng chip A19\ncùng iOS 26 tích hợp Apple Intelligence\nvào nhiều tính năng quen thuộc.\nNhờ đó, máy xử lý nhanh, đáp ứng\ntốt nhu cầu làm việc, giải trí và liên lạc."
        app:layout_constraintLeft_toRightOf="@id/iv1"
        app:layout_constraintTop_toBottomOf="@id/tx1"
        android:textSize="11dp"
        android:layout_marginTop="60dp"
        />

    <Button
        android:id="@+id/bt1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="52dp"
        android:text="TRANG CHU"
        android:textColor="@color/black"
        app:layout_constraintLeft_toLeftOf="@id/iv1"
        app:layout_constraintTop_toBottomOf="@id/iv1"
        android:background="@drawable/button1"
        app:backgroundTint="@null"/>

    <Button
        android:id="@+id/bt2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MUA"
        android:textColor="@color/black"
        app:layout_constraintLeft_toRightOf ="@id/bt1"
        app:layout_constraintTop_toTopOf="@id/bt1"
        android:layout_marginLeft="10dp"
        android:background="@drawable/button1"
        app:backgroundTint="@null"
        />
    <Button
        android:id="@+id/bt3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHI TIET"
        android:textColor="@color/black"
        app:layout_constraintLeft_toRightOf ="@id/bt2"
        app:layout_constraintTop_toTopOf="@id/bt1"
        android:layout_marginLeft="10dp"
        android:background="@drawable/button1"
        app:backgroundTint="@null"
        />
</androidx.constraintlayout.widget.ConstraintLayout>